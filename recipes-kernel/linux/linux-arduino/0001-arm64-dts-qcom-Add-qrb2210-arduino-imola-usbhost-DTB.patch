From 4457a8bd71027c7c7e31a29a083bb7696076ecec Mon Sep 17 00:00:00 2001
From: Dmitry Baryshkov <dmitry.baryshkov@oss.qualcomm.com>
Date: Sat, 27 Jun 2026 02:49:14 +0300
Subject: [PATCH] arm64: dts: qcom: Add qrb2210-arduino-imola-usbhost DTB

U-Boot reuses kernel DTBs but cannot detect USB role dynamically, so
a dedicated USB host mode variant is required.

Add qrb2210-arduino-imola-usbhost which includes the base Imola DTS
and overrides the USB controller to dr_mode = "host", removing the
role-switch property.

Signed-off-by: Dmitry Baryshkov <dmitry.baryshkov@oss.qualcomm.com>
Upstream-Status: Inappropriate [DT specific to meta-qcom-3rdparty to be used by U-Boot]
---
 arch/arm64/boot/dts/qcom/Makefile                     |  3 +++
 .../dts/qcom/qrb2210-arduino-imola-base-usbhost.dts   | 11 +++++++++++
 2 files changed, 14 insertions(+)
 create mode 100644 arch/arm64/boot/dts/qcom/qrb2210-arduino-imola-base-usbhost.dts

diff --git a/arch/arm64/boot/dts/qcom/Makefile b/arch/arm64/boot/dts/qcom/Makefile
index 4ac881fee600..8b1577e8df26 100644
--- a/arch/arm64/boot/dts/qcom/Makefile
+++ b/arch/arm64/boot/dts/qcom/Makefile
@@ -176,6 +176,9 @@ dtb-$(CONFIG_ARCH_QCOM)	+= qrb2210-arduino-imola-carrier-media-full-4lanes.dtb
 qrb2210-arduino-imola-carrier-media-full-2lanes-dtbs := qrb2210-arduino-imola-base.dtb qrb2210-arduino-imola-carrier-media.dtbo qrb2210-arduino-imola-carrier-media-camera-imx219-csi0-2lanes.dtbo qrb2210-arduino-imola-carrier-media-camera-imx219-csi1-2lanes.dtbo qrb2210-arduino-imola-carrier-media-panel-8in_touch_a-dsi.dtbo
 dtb-$(CONFIG_ARCH_QCOM)	+= qrb2210-arduino-imola-carrier-media-full-2lanes.dtb
 
+qrb2210-arduino-imola-usbhost-dtbs := qrb2210-arduino-imola-base-usbhost.dtb qrb2210-arduino-imola-video_sound-usbc.dtbo
+dtb-$(CONFIG_ARCH_QCOM)	+= qrb2210-arduino-imola-usbhost.dtb
+
 dtb-$(CONFIG_ARCH_QCOM)	+= qrb2210-rb1.dtb
 
 qrb2210-rb1-vision-mezzanine-dtbs	:= qrb2210-rb1.dtb qrb2210-rb1-vision-mezzanine.dtbo
diff --git a/arch/arm64/boot/dts/qcom/qrb2210-arduino-imola-base-usbhost.dts b/arch/arm64/boot/dts/qcom/qrb2210-arduino-imola-base-usbhost.dts
new file mode 100644
index 000000000000..af310105b9f5
--- /dev/null
+++ b/arch/arm64/boot/dts/qcom/qrb2210-arduino-imola-base-usbhost.dts
@@ -0,0 +1,11 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR BSD-3-Clause)
+/*
+ * Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.
+ */
+
+#include "qrb2210-arduino-imola-base.dts"
+
+&usb_dwc3 {
+	dr_mode = "host";
+	/delete-property/ usb-role-switch;
+};
